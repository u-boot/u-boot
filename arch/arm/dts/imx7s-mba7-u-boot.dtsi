#include "imx7s-u-boot.dtsi"

/ {
	config {
		u-boot,mmc-env-offset = <0x100000>;
		u-boot,mmc-env-offset-redundant = <0x110000>;
	};

	wdt-reboot {
		compatible = "wdt-reboot";
		wdt = <&wdog1>;
	};
};

&wdog1 {
	u-boot,noautostart;
	timeout-sec = <60>;
};
