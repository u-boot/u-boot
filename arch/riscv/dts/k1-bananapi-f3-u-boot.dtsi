#include "binman.dtsi"

/ {
	memory@0 {
		device_type = "memory";
		reg = <0x00000000 0x00000000 0x00000000 0x80000000>;
	};
};

&uart0 {
	bootph-pre-ram;
};

&osc_32k {
	bootph-pre-ram;
};

&vctcxo_1m {
	bootph-pre-ram;
};

&vctcxo_3m {
	bootph-pre-ram;
};

&vctcxo_24m {
	bootph-pre-ram;
};

&syscon_mpmu {
	bootph-pre-ram;
};

&pll {
	bootph-pre-ram;
};

&syscon_apmu {
	bootph-pre-ram;
};

&syscon_apbc {
	bootph-pre-ram;
};

&i2c2 {
	bootph-pre-ram;
	resets = <&syscon_apbc RESET_TWSI2>;

	eeprom@50 {
		bootph-pre-ram;
	};
};
